{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "preferences": {
          "type": "object",
          "properties": {
            "darkMode": { "type": "boolean" },
            "notificationsEnabled": { "type": "boolean" },
            "language": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A habit defined by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "frequency": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["daily", "weekly", "custom"] },
            "days": { "type": "array", "items": { "type": "number" } }
          }
        },
        "reminderTime": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "archived": { "type": "boolean" }
      },
      "required": ["userId", "name", "category"]
    },
    "HabitLog": {
      "title": "Habit Log",
      "description": "Daily completion record for a habit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "habitId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["completed", "missed", "skipped"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "habitId", "date", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/habits/{habitId}": {
      "schema": "Habit",
      "description": "Habit definitions"
    },
    "/logs/{logId}": {
      "schema": "HabitLog",
      "description": "Completion logs"
    }
  }
}
